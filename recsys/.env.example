# Same values as backend/.env — copy directly
MONGODB_URI=mongodb+srv://user:pass@host/spacic_db?appName=Users
REDIS_URL=redis://default:pass@host:port

# Must match RECSYS_INTERNAL_API_KEY in backend/.env
RECSYS_INTERNAL_API_KEY=spacic-recsys-internal-2026

# Model tuning
ALS_FACTORS=64
ALS_ITERATIONS=20
TRAIN_HOUR_UTC=2
MLFLOW_TRACKING_URI=mlite
