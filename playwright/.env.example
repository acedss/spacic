# Frontend / API origins
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:4000

# Dev-token bypass — must match backend .env DEV_TOKEN_VALUE.
# Lets the recorded session inject `x-dev-token` for any HTTP call instead
# of running the Clerk sign-in flow on camera.
DEV_TOKEN=spacic-dev-2026

# The dev account that DEV_TOKEN authenticates as. Same value as backend DEV_CLERK_ID.
DEV_CLERK_ID=user_383URuiYNKZtUx9xn1aNla2meRe

# The five seeded room slugs from seedDemo.js. Used by the demo spec to pick a
# specific room to record. The Live page is reached via /rooms/<roomKey>.
DEMO_ROOM_KEY_MIDNIGHT=midnight-standards
DEMO_ROOM_KEY_DOOWOP=doo-wop-diner
DEMO_ROOM_KEY_SOUL=soul-slow-jams
DEMO_ROOM_KEY_RNB=modern-rnb-lounge
DEMO_ROOM_KEY_LAB=spacic-studio-lab

# Ghost listeners — these clerkIds exist in the seeded DB. Socket.IO accepts
# the clerkId in handshake.auth without further verification (see backend/src/lib/socket.js:1297).
GHOST_CLERK_ID_1=demo_listener_lila
GHOST_CLERK_ID_2=demo_listener_aki
GHOST_CLERK_ID_3=demo_listener_juno
GHOST_CLERK_ID_4=demo_listener_ren
